# ─── Evolution API (WhatsApp) ────────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE=limpower
EVOLUTION_API_KEY=seu-api-key-aqui

# ─── Google Calendar ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret
GOOGLE_REFRESH_TOKEN=seu-refresh-token
# Use "primary" para o calendário principal ou cole o ID de um calendário específico
GOOGLE_CALENDAR_ID=primary

# ─── Horários de atendimento ──────────────────────────────────────────────────
TIMEZONE=America/Sao_Paulo
# Dias da semana: 0=Dom, 1=Seg, 2=Ter, 3=Qua, 4=Qui, 5=Sex, 6=Sáb
WORKING_DAYS=1,2,3,4,5
WORKING_HOURS_START=8
WORKING_HOURS_END=18

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sua-chave-anthropic

# ─── Fernanda (aprovações) ────────────────────────────────────────────────────
# Número da Fernanda com DDI+DDD, sem espaços ou símbolos (ex: 5511988325990)
FERNANDA_PHONE=5511964636067

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
